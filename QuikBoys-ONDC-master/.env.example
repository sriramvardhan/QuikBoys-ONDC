# =============================================================================
# QuikBoys ONDC Module — Environment Variables
# Copy this to .env.local and fill in the values
# =============================================================================

# Server
PORT=3001
NODE_ENV=development
CORS_ORIGINS=http://localhost:3000

# Database (PostgreSQL)
DATABASE_URL=postgresql://user:password@localhost:5432/quikboys_ondc

# API Base URL (monolith backend — for callback URL generation)
API_BASE_URL=http://localhost:3000

# =============================================================================
# ONDC Configuration
# =============================================================================

# Environment: staging | production
ONDC_ENVIRONMENT=staging

# Registry URLs
ONDC_REGISTRY_URL=https://staging.registry.ondc.org
ONDC_GATEWAY_URL=https://staging.gateway.ondc.org

# Subscriber Details (from ONDC portal)
ONDC_SUBSCRIBER_ID=
ONDC_SUBSCRIBER_URL=
ONDC_UNIQUE_KEY_ID=ed25519.k1

# Site verification (from ONDC portal)
ONDC_SIGNED_REQUEST_ID=

# Ed25519 Signing Keys (Base64 encoded)
ONDC_SIGNING_PRIVATE_KEY=
ONDC_SIGNING_PUBLIC_KEY=

# X25519 Encryption Keys (optional — for sensitive data)
ONDC_ENCRYPTION_PRIVATE_KEY=
ONDC_ENCRYPTION_PUBLIC_KEY=

# Provider Details
ONDC_PROVIDER_ID=P1
ONDC_PROVIDER_NAME=QuikBoys Logistics
ONDC_PROVIDER_SHORT_DESC=Hyperlocal delivery services
ONDC_PROVIDER_LONG_DESC=Fast and reliable last-mile delivery for food, groceries, and packages

# Domain Configuration
ONDC_DOMAIN=ONDC:LOG
ONDC_CITY_CODE=std:040
ONDC_COUNTRY=IND

# Callback Configuration
ONDC_CALLBACK_TIMEOUT_MS=30000
ONDC_CALLBACK_RETRY_COUNT=3
ONDC_CALLBACK_RETRY_DELAY_MS=5000

# Pricing Configuration (distance-based)
ONDC_BASE_FARE=30
ONDC_PER_KM_RATE=10
ONDC_PER_KG_RATE=5
ONDC_MINIMUM_FARE=40
ONDC_TAX_RATE=0.18

# Tracking
ONDC_TRACKING_BASE_URL=https://track.quikboys.in

# Trusted Test BAPs (comma-separated — for Pramaan sandbox testing)
ONDC_TRUSTED_TEST_BAPS=

# TTL Configuration (seconds)
ONDC_TTL_SEARCH=30
ONDC_TTL_SELECT=30
ONDC_TTL_INIT=30
ONDC_TTL_CONFIRM=30
ONDC_TTL_STATUS=30
ONDC_TTL_TRACK=30
ONDC_TTL_CANCEL=30
ONDC_TTL_UPDATE=30
